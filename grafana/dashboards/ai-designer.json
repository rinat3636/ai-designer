{
  "id": null,
  "uid": "ai-designer",
  "title": "AI Designer",
  "tags": ["ai-designer", "llm"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Request rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (model, status, error_type) (rate(chat_requests_total[1m]))",
          "legendFormat": "{{model}} / {{status}} / {{error_type}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "linear" },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 2,
      "title": "p95 response duration",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, model) (rate(chat_response_duration_ms_bucket[5m])))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "linear" },
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 3,
      "title": "Token rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (model) (rate(chat_tokens_total[1m]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "linear" },
          "unit": "tps"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 4,
      "title": "524 error share",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(chat_requests_total{error_type=\"524\"}[5m])) / sum(rate(chat_requests_total[5m]))",
          "legendFormat": "524 share",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "linear" },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {}
    }
  ]
}
